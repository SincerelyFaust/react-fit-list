{
  "name": "react-fit-list",
  "version": "1.0.4",
  "description": "A headless React utility for rendering a single horizontal row of items, keeping what fits visible and collapsing the rest behind an overflow trigger.",
  "keywords": [
    "react",
    "fit-list",
    "overflow",
    "single-row",
    "headless",
    "chips",
    "tags",
    "breadcrumbs",
    "responsive",
    "typescript",
    "ui"
  ],
  "homepage": "https://sincerelyfaust.github.io/react-fit-list/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SincerelyFaust/react-fit-list.git"
  },
  "bugs": {
    "url": "https://github.com/SincerelyFaust/react-fit-list/issues"
  },
  "license": "MIT",
  "author": "Marin Heđeš",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  }
}
